{
  "name": "clawnexus-plugin",
  "version": "0.2.7",
  "description": "OpenClaw plugin adapter for ClawNexus daemon",
  "license": "MIT",
  "author": "alan-silverstreams <alan@silverstream.tech>",
  "homepage": "https://github.com/SilverstreamsAI/ClawNexus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SilverstreamsAI/ClawNexus.git",
    "directory": "packages/plugin"
  },
  "bugs": "https://github.com/SilverstreamsAI/ClawNexus/issues",
  "keywords": [
    "openclaw",
    "plugin",
    "clawnexus",
    "ai",
    "agent",
    "registry",
    "discovery"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "clawnexus": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
