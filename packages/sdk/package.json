{
  "name": "@clawnexus/sdk",
  "version": "0.2.7",
  "description": "ClawNexus SDK — programmatic client for discovering and managing OpenClaw instances",
  "license": "MIT",
  "author": "alan-silverstreams <alan@silverstream.tech>",
  "homepage": "https://github.com/SilverstreamsAI/ClawNexus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SilverstreamsAI/ClawNexus.git",
    "directory": "packages/sdk"
  },
  "bugs": "https://github.com/SilverstreamsAI/ClawNexus/issues",
  "keywords": [
    "openclaw",
    "ai",
    "agent",
    "sdk",
    "clawlink",
    "protocol",
    "discovery",
    "clawnexus"
  ],
  "main": "dist/index.js",
